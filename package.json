{
  "name": "blueprint-implementer",
  "version": "1.0.0",
  "description": "A web-based authoring environment for writing structured markdown blueprints and implementing them into executable applications using the Copilot SDK",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/server.mjs",
    "dev": "npm run build && npm start",
    "test": "node test/interact.mjs",
    "install-cli": "npm run build && cd cli && npm pack && npm install -g blueprint-1.0.0.tgz"
  },
  "dependencies": {
    "@github/copilot": "^0.0.405",
    "@github/copilot-sdk": "^0.1.23",
    "@xterm/xterm": "^5.5.0",
    "express": "^5.0.0",
    "marked": "^15.0.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.24.0",
    "playwright": "^1.48.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
