{
  "name": "blueprint-implementer",
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE.txt",
  "private": true,
  "type": "module",
  "main": "dist/electron.cjs",
  "scripts": {
    "build": "node build.mjs",
    "start": "electron .",
    "dev": "npm run build && npm run start",
    "implement": "node dist/implement-cli.mjs",
    "package": "npm run build && electron-packager . Blueprint --platform=darwin --arch=arm64 --out=release --overwrite --ignore=\"^/(src|test|blueprint|tsconfig|build\\.mjs|playwright)\""
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "electron": "^33.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@github/copilot": "^0.0.406",
    "@github/copilot-sdk": "^0.1.23",
    "@xterm/xterm": "^6.0.0",
    "marked": "^12.0.0",
    "node-pty": "^1.1.0"
  }
}
